# Anthropic API key -- powers the chat agent
ANTHROPIC_API_KEY=sk-ant-...

# Chat model (any Claude model id). Haiku keeps costs minimal; use
# claude-sonnet-5 for higher-quality answers.
WATCHBOT_MODEL=claude-haiku-4-5

# OpenAI API key -- used only for text embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# congress.gov API key -- free signup at https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=...

# Postgres with the pgvector extension. The default matches the container
# started by `docker compose up -d` (see compose.yml).
DATABASE_URL=postgresql://postgres:watchbot@localhost:5433/watchbot

# Command used to launch the GovQL MCP server.
GOVQL_MCP_COMMAND=uvx govql-mcp-server

# Which Congress to ingest and talk about. 119 = 2025-2026.
CONGRESS=119
